{
    "compilerOptions": {
      "target": "es5",
      "allowJs": true,
      "skipLibCheck": true,
      "strict": false,
      "forceConsistentCasingInFileNames": true,
      "noEmit": true,
      "esModuleInterop": true,
      "module": "Node16",
      "moduleResolution": "Node16",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "jsx": "preserve",
      "baseUrl": ".",
      "incremental": true,
      "strictNullChecks": true
    },
    "include": ["."],
    "exclude": ["node_modules"]
  }
    